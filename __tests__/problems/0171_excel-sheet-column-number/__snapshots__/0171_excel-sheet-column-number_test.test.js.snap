// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`0171_excel-sheet-column-number test template: 0171_excel-sheet-column-number 1`] = `
"import { describe, expect, test } from 'bun:test';
import { titleToNumber } from '../../src/0101-0200/0171_excel-sheet-column-number.js';

const testcases = [
    { columnTitle: "A", expected: 1 },
    { columnTitle: "AB", expected: 28 },
    { columnTitle: "ZY", expected: 701 },
];

describe('titleToNumber', () => {
    test.each(structuredClone(testcases))('titleToNumber($columnTitle) -> $expected', ({ columnTitle, expected }) => {
        expect(titleToNumber(columnTitle)).toStrictEqual(expected);
    });
});"
`;
