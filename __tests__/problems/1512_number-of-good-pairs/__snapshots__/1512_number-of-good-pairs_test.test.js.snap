exports[`1512_number-of-good-pairs test template: 1512_number-of-good-pairs 1`] = `
"import { describe, expect, test } from 'bun:test';
import { numIdenticalPairs } from '../../src/1501-1600/1512_number-of-good-pairs.js';

const testcases = [
    { nums: [1,2,3,1,1,3], expected: 4 },
    { nums: [1,1,1,1], expected: 6 },
    { nums: [1,2,3], expected: 0 },
];

describe('numIdenticalPairs', () => {
    test.each(structuredClone(testcases))('numIdenticalPairs($nums) -> $expected', ({ nums, expected }) => {
        expect(numIdenticalPairs(nums)).toStrictEqual(expected);
    });
});"
`;
