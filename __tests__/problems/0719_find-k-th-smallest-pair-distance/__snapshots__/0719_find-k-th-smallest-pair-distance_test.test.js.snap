exports[`0719_find-k-th-smallest-pair-distance test template: 0719_find-k-th-smallest-pair-distance 1`] = `
"import { describe, expect, test } from 'bun:test';
import { smallestDistancePair } from '../../src/0701-0800/0719_find-k-th-smallest-pair-distance.js';

const testcases = [
    { nums: [1,3,1], k: 1, expected: 0 },
    { nums: [1,1,1], k: 2, expected: 0 },
    { nums: [1,6,1], k: 3, expected: 5 },
];

describe('smallestDistancePair', () => {
    test.each(structuredClone(testcases))('smallestDistancePair($nums, $k) -> $expected', ({ nums, k, expected }) => {
        expect(smallestDistancePair(nums, k)).toStrictEqual(expected);
    });
});"
`;
