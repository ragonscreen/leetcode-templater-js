exports[`1822_sign-of-the-product-of-an-array test template: 1822_sign-of-the-product-of-an-array 1`] = `
"import { describe, expect, test } from 'bun:test';
import { arraySign } from '../../src/1801-1900/1822_sign-of-the-product-of-an-array.js';

const testcases = [
    { nums: [-1,-2,-3,-4,3,2,1], expected: 1 },
    { nums: [1,5,0,2,-3], expected: 0 },
    { nums: [-1,1,-1,1,-1], expected: -1 },
];

describe('arraySign', () => {
    test.each(structuredClone(testcases))('arraySign($nums) -> $expected', ({ nums, expected }) => {
        expect(arraySign(nums)).toStrictEqual(expected);
    });
});"
`;
