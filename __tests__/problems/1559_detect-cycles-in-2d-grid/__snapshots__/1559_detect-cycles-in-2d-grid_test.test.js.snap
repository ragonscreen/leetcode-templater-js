// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`1559_detect-cycles-in-2d-grid test template: 1559_detect-cycles-in-2d-grid 1`] = `
"import { describe, expect, test } from 'bun:test';
import { containsCycle } from '../../src/1501-1600/1559_detect-cycles-in-2d-grid.js';

const testcases = [
    { grid: [["a","a","a","a"],["a","b","b","a"],["a","b","b","a"],["a","a","a","a"]], expected: true },
    { grid: [["c","c","c","a"],["c","d","c","c"],["c","c","e","c"],["f","c","c","c"]], expected: true },
    { grid: [["a","b","b"],["b","z","b"],["b","b","a"]], expected: false },
];

describe('containsCycle', () => {
    test.each(structuredClone(testcases))('containsCycle($grid) -> $expected', ({ grid, expected }) => {
        expect(containsCycle(grid)).toStrictEqual(expected);
    });
});"
`;
