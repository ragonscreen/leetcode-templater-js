exports[`1675_minimize-deviation-in-array test template: 1675_minimize-deviation-in-array 1`] = `
"import { describe, expect, test } from 'bun:test';
import { minimumDeviation } from '../../src/1601-1700/1675_minimize-deviation-in-array.js';

const testcases = [
    { nums: [1,2,3,4], expected: 1 },
    { nums: [4,1,5,20,3], expected: 3 },
    { nums: [2,10,8], expected: 3 },
];

describe('minimumDeviation', () => {
    test.each(structuredClone(testcases))('minimumDeviation($nums) -> $expected', ({ nums, expected }) => {
        expect(minimumDeviation(nums)).toStrictEqual(expected);
    });
});"
`;
