exports[`0632_smallest-range-covering-elements-from-k-lists test template: 0632_smallest-range-covering-elements-from-k-lists 1`] = `
"import { describe, expect, test } from 'bun:test';
import { smallestRange } from '../../src/0601-0700/0632_smallest-range-covering-elements-from-k-lists.js';

const testcases = [
    { nums: [[4,10,15,24,26],[0,9,12,20],[5,18,22,30]], expected: [20,24] },
    { nums: [[1,2,3],[1,2,3],[1,2,3]], expected: [1,1] },
];

describe('smallestRange', () => {
    test.each(structuredClone(testcases))('smallestRange($nums) -> $expected', ({ nums, expected }) => {
        expect(smallestRange(nums)).toStrictEqual(expected);
    });
});"
`;
