import { findThePrefixCommonArray } from '../../src/2601-2700/2657_find-the-prefix-common-array-of-two-arrays.js';

const testcases = [
    { A: [1,3,2,4], B: [3,1,2,4], expected: [0,2,3,4] },
    { A: [2,3,1], B: [3,1,2], expected: [0,1,3] },
];

describe('findThePrefixCommonArray', () => {
    test.each(structuredClone(testcases))('findThePrefixCommonArray($A, $B) -> $expected', ({ A, B, expected }) => {
        expect(findThePrefixCommonArray(A, B)).toStrictEqual(expected);
    });
});"
