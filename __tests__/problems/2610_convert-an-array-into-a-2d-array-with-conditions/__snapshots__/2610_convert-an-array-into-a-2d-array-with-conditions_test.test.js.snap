// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`2610_convert-an-array-into-a-2d-array-with-conditions test template: 2610_convert-an-array-into-a-2d-array-with-conditions 1`] = `
"import { describe, expect, test } from 'bun:test';
import { findMatrix } from '../../src/2601-2700/2610_convert-an-array-into-a-2d-array-with-conditions.js';

const testcases = [
    { nums: [1,3,4,1,2,3,1], expected: [[1,3,4,2],[1,3],[1]] },
    { nums: [2,1,1], expected: [[1,2],[1]] },
    { nums: [1,2,3,4], expected: [[4,3,2,1]] },
];

describe('findMatrix', () => {
    test.each(structuredClone(testcases))('findMatrix($nums) -> $expected', ({ nums, expected }) => {
        const actual = findMatrix(nums);

        for (let i = 0; i < expected.length; i++) {
            expect(actual[i]).toContainAllValues(expected[i]);
        }
    });
});"
`;
