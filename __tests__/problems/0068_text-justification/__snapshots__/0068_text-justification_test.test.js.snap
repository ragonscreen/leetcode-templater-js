// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`0068_text-justification test template: 0068_text-justification 1`] = `
"import { describe, expect, test } from 'bun:test';
import { fullJustify } from '../../src/0001-0100/0068_text-justification.js';

const testcases = [
    { words: ["This","is","an","example","of","text","justification."], maxWidth: 16, expected: ["This    is    an","example  of text","justification.  "] },
    { words: ["What","must","be","acknowledgment","shall","be"], maxWidth: 16, expected: ["What   must   be","acknowledgment  ","shall be        "] },
    { words: ["Science","is","what","we","understand","well","enough","to","explain","to","a","computer.","Art","is","everything","else","we","do"], maxWidth: 20, expected: ["Science  is  what we","understand      well","enough to explain to","a  computer.  Art is","everything  else  we","do                  "] },
];

describe('fullJustify', () => {
    test.each(structuredClone(testcases))('fullJustify($words, $maxWidth) -> $expected', ({ words, maxWidth, expected }) => {
        expect(fullJustify(words, maxWidth)).toStrictEqual(expected);
    });
});"
`;
