exports[`0018_4sum test template: 0018_4sum 1`] = `
"import { describe, expect, test } from 'bun:test';
import { fourSum } from '../../src/0001-0100/0018_4sum.js';

const testcases = [
    { nums: [1,0,-1,0,-2,2], target: 0, expected: [[-2,-1,1,2],[-2,0,0,2],[-1,0,0,1]] },
    { nums: [2,2,2,2,2], target: 8, expected: [[2,2,2,2]] },
];

describe('fourSum', () => {
    test.each(structuredClone(testcases))('fourSum($nums, $target) -> $expected', ({ nums, target, expected }) => {
        expect(fourSum(nums, target)).toStrictEqual(expected);
    });
});"
`;
