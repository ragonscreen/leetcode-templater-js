const testcases = [
    { s: "aczzx", expected: 5 },
    { s: "abcdef", expected: 0 },
];

describe('calculateScore', () => {
    test.each(structuredClone(testcases))('calculateScore($s) -> $expected', ({ s, expected }) => {
        expect(calculateScore(s)).toStrictEqual(expected);
    });
});"
