describe('shortestPathAllKeys', () => {
    test.each(structuredClone(testcases))('shortestPathAllKeys($grid) -> $expected', ({ grid, expected }) => {
        expect(shortestPathAllKeys(grid)).toStrictEqual(expected);
    });
});"
