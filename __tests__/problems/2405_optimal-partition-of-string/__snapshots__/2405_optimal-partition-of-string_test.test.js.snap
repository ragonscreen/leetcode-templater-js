const testcases = [
    { s: "abacaba", expected: 4 },
    { s: "ssssss", expected: 6 },
];

describe('partitionString', () => {
    test.each(structuredClone(testcases))('partitionString($s) -> $expected', ({ s, expected }) => {
        expect(partitionString(s)).toStrictEqual(expected);
    });
});"
