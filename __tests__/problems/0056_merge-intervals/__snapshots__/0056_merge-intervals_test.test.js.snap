"import { describe, expect, test } from 'bun:test';
import { merge } from '../../src/0001-0100/0056_merge-intervals.js';

const testcases = [
    { intervals: [[1,3],[2,6],[8,10],[15,18]], expected: [[1,6],[8,10],[15,18]] },
    { intervals: [[1,4],[4,5]], expected: [[1,5]] },
    { intervals: [[4,7],[1,4]], expected: [[1,7]] },
];

describe('merge', () => {
    test.each(structuredClone(testcases))('merge($intervals) -> $expected', ({ intervals, expected }) => {
        expect(merge(intervals)).toStrictEqual(expected);
    });
});"
`;
