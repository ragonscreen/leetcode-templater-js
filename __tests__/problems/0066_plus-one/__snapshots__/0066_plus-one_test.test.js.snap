exports[`0066_plus-one test template: 0066_plus-one 1`] = `
"import { describe, expect, test } from 'bun:test';
import { plusOne } from '../../src/0001-0100/0066_plus-one.js';

const testcases = [
    { digits: [1,2,3], expected: [1,2,4] },
    { digits: [4,3,2,1], expected: [4,3,2,2] },
    { digits: [9], expected: [1,0] },
];

describe('plusOne', () => {
    test.each(structuredClone(testcases))('plusOne($digits) -> $expected', ({ digits, expected }) => {
        expect(plusOne(digits)).toStrictEqual(expected);
    });
});"
`;
