const testcases = [
    { prices: [7,1,5,3,6,4], expected: 5 },
    { prices: [7,6,4,3,1], expected: 0 },
];

describe('maxProfit', () => {
    test.each(structuredClone(testcases))('maxProfit($prices) -> $expected', ({ prices, expected }) => {
        expect(maxProfit(prices)).toStrictEqual(expected);
    });
});"
`;
