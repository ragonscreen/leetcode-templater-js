exports[`1351_count-negative-numbers-in-a-sorted-matrix test template: 1351_count-negative-numbers-in-a-sorted-matrix 1`] = `
"import { describe, expect, test } from 'bun:test';
import { countNegatives } from '../../src/1301-1400/1351_count-negative-numbers-in-a-sorted-matrix.js';

const testcases = [
    { grid: [[4,3,2,-1],[3,2,1,-1],[1,1,-1,-2],[-1,-1,-2,-3]], expected: 8 },
    { grid: [[3,2],[1,0]], expected: 0 },
];

describe('countNegatives', () => {
    test.each(structuredClone(testcases))('countNegatives($grid) -> $expected', ({ grid, expected }) => {
        expect(countNegatives(grid)).toStrictEqual(expected);
    });
});"
`;
