const testcases = [
    { a: "11", b: "1", expected: "100" },
    { a: "1010", b: "1011", expected: "10101" },
];

describe('addBinary', () => {
    test.each(structuredClone(testcases))('addBinary($a, $b) -> $expected', ({ a, b, expected }) => {
        expect(addBinary(a, b)).toStrictEqual(expected);
    });
});"
