const testcases = [
    { encodedText: "ch   ie   pr", rows: 3, expected: "cipher" },
    { encodedText: "iveo    eed   l te   olc", rows: 4, expected: "i love leetcode" },
    { encodedText: "coding", rows: 1, expected: "coding" },
