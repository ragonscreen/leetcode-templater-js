"import { describe, expect, test } from 'bun:test';
import { findMinDifference } from '../../src/0501-0600/0539_minimum-time-difference.js';

const testcases = [
    { timePoints: ["23:59","00:00"], expected: 1 },
    { timePoints: ["00:00","23:59","00:00"], expected: 0 },
];

describe('findMinDifference', () => {
    test.each(structuredClone(testcases))('findMinDifference($timePoints) -> $expected', ({ timePoints, expected }) => {
        expect(findMinDifference(timePoints)).toStrictEqual(expected);
    });
});"
`;
