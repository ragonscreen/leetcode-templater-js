exports[`2516_take-k-of-each-character-from-left-and-right test template: 2516_take-k-of-each-character-from-left-and-right 1`] = `
"import { describe, expect, test } from 'bun:test';
import { takeCharacters } from '../../src/2501-2600/2516_take-k-of-each-character-from-left-and-right.js';

const testcases = [
    { s: "aabaaaacaabc", k: 2, expected: 8 },
    { s: "a", k: 1, expected: -1 },
];

describe('takeCharacters', () => {
    test.each(structuredClone(testcases))('takeCharacters($s, $k) -> $expected', ({ s, k, expected }) => {
        expect(takeCharacters(s, k)).toStrictEqual(expected);
    });
});"
`;
