exports[`2017_grid-game test template: 2017_grid-game 1`] = `
"import { describe, expect, test } from 'bun:test';
import { gridGame } from '../../src/2001-2100/2017_grid-game.js';

const testcases = [
    { grid: [[2,5,4],[1,5,1]], expected: 4 },
    { grid: [[3,3,1],[8,5,2]], expected: 4 },
    { grid: [[1,3,1,15],[1,3,3,1]], expected: 7 },
];

describe('gridGame', () => {
    test.each(structuredClone(testcases))('gridGame($grid) -> $expected', ({ grid, expected }) => {
        expect(gridGame(grid)).toStrictEqual(expected);
    });
});"
`;
