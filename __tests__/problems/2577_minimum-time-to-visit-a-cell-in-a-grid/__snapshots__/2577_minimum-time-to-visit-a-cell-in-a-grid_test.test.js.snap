exports[`2577_minimum-time-to-visit-a-cell-in-a-grid test template: 2577_minimum-time-to-visit-a-cell-in-a-grid 1`] = `
"import { describe, expect, test } from 'bun:test';
import { minimumTime } from '../../src/2501-2600/2577_minimum-time-to-visit-a-cell-in-a-grid.js';

const testcases = [
    { grid: [[0,1,3,2],[5,1,2,5],[4,3,8,6]], expected: 7 },
    { grid: [[0,2,4],[3,2,1],[1,0,4]], expected: -1 },
];

describe('minimumTime', () => {
    test.each(structuredClone(testcases))('minimumTime($grid) -> $expected', ({ grid, expected }) => {
        expect(minimumTime(grid)).toStrictEqual(expected);
    });
});"
`;
