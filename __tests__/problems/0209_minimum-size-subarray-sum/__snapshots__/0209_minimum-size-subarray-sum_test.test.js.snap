exports[`0209_minimum-size-subarray-sum test template: 0209_minimum-size-subarray-sum 1`] = `
"import { describe, expect, test } from 'bun:test';
import { minSubArrayLen } from '../../src/0201-0300/0209_minimum-size-subarray-sum.js';

const testcases = [
    { target: 7, nums: [2,3,1,2,4,3], expected: 2 },
    { target: 4, nums: [1,4,4], expected: 1 },
    { target: 11, nums: [1,1,1,1,1,1,1,1], expected: 0 },
];

describe('minSubArrayLen', () => {
    test.each(structuredClone(testcases))('minSubArrayLen($target, $nums) -> $expected', ({ target, nums, expected }) => {
        expect(minSubArrayLen(target, nums)).toStrictEqual(expected);
    });
});"
`;
