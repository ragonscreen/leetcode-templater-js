// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`1374_generate-a-string-with-characters-that-have-odd-counts test template: 1374_generate-a-string-with-characters-that-have-odd-counts 1`] = `
"import { describe, expect, test } from 'bun:test';
import { generateTheString } from '../../src/1301-1400/1374_generate-a-string-with-characters-that-have-odd-counts.js';

const testcases = [
    { n: 4, expected: undefined },
    { n: 2, expected: undefined },
    { n: 7, expected: undefined },
];

describe('generateTheString', () => {
    test.each(structuredClone(testcases))('generateTheString($n) -> $expected', ({ n, expected }) => {
        const countMap = new Map();
        const actual = generateTheString(n);

        for (const char of actual) {
            countMap.set(char, (countMap.get(char) || 0) + 1);
        }

        expect(actual).toHaveLength(n);
        expect(countMap.values().every((e) => e % 2)).toStrictEqual(true);
    });
});"
`;
