// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`0724_find-pivot-index test template: 0724_find-pivot-index 1`] = `
"import { describe, expect, test } from 'bun:test';
import { pivotIndex } from '../../src/0701-0800/0724_find-pivot-index.js';

const testcases = [
    { nums: [1,7,3,6,5,6], expected: 3 },
    { nums: [1,2,3], expected: -1 },
    { nums: [2,1,-1], expected: 0 },
];

describe('pivotIndex', () => {
    test.each(structuredClone(testcases))('pivotIndex($nums) -> $expected', ({ nums, expected }) => {
        expect(pivotIndex(nums)).toStrictEqual(expected);
    });
});"
`;
