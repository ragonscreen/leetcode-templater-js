const testcases = [
    { matrix: [[9,9,4],[6,6,8],[2,1,1]], expected: 4 },
    { matrix: [[3,4,5],[3,2,6],[2,2,1]], expected: 4 },
    { matrix: [[1]], expected: 1 },
];

describe('longestIncreasingPath', () => {
    test.each(structuredClone(testcases))('longestIncreasingPath($matrix) -> $expected', ({ matrix, expected }) => {
        expect(longestIncreasingPath(matrix)).toStrictEqual(expected);
    });
});"
