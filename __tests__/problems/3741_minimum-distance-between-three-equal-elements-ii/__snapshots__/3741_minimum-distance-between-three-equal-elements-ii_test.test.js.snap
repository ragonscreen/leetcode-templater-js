exports[`3741_minimum-distance-between-three-equal-elements-ii test template: 3741_minimum-distance-between-three-equal-elements-ii 1`] = `
"import { describe, expect, test } from 'bun:test';
import { minimumDistance } from '../../src/3701-3800/3741_minimum-distance-between-three-equal-elements-ii.js';

const testcases = [
    { nums: [1,2,1,1,3], expected: 6 },
    { nums: [1,1,2,3,2,1,2], expected: 8 },
    { nums: [1], expected: -1 },
];

describe('minimumDistance', () => {
    test.each(structuredClone(testcases))('minimumDistance($nums) -> $expected', ({ nums, expected }) => {
        expect(minimumDistance(nums)).toStrictEqual(expected);
    });
});"
