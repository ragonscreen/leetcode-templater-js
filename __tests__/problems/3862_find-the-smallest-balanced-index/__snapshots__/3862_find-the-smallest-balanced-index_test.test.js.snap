exports[`3862_find-the-smallest-balanced-index test template: 3862_find-the-smallest-balanced-index 1`] = `
"import { describe, expect, test } from 'bun:test';
import { smallestBalancedIndex } from '../../src/3801-3900/3862_find-the-smallest-balanced-index.js';

const testcases = [
    { nums: [2,1,2], expected: 1 },
    { nums: [2,8,2,2,5], expected: 2 },
    { nums: [1], expected: -1 },
];

describe('smallestBalancedIndex', () => {
    test.each(structuredClone(testcases))('smallestBalancedIndex($nums) -> $expected', ({ nums, expected }) => {
        expect(smallestBalancedIndex(nums)).toStrictEqual(expected);
    });
});"
`;
