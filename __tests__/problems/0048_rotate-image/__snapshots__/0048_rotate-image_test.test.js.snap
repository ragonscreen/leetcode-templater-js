// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`0048_rotate-image test template: 0048_rotate-image 1`] = `
"import { describe, expect, test } from 'bun:test';
import { rotate } from '../../src/0001-0100/0048_rotate-image.js';

const testcases = [
    { matrix: [[1,2,3],[4,5,6],[7,8,9]], expected: [[7,4,1],[8,5,2],[9,6,3]] },
    { matrix: [[5,1,9,11],[2,4,8,10],[13,3,6,7],[15,14,12,16]], expected: [[15,13,2,5],[14,3,4,1],[12,6,8,9],[16,7,10,11]] },
];

describe('rotate', () => {
    test.each(structuredClone(testcases))('rotate($matrix) -> $expected', ({ matrix, expected }) => {
        expect(rotate(matrix)).toBeNil();

        for (let i = 0; i < matrix.length; i++) {
            expect(matrix[i]).toStrictEqual(expected[i]);
        }
    });
});"
`;
