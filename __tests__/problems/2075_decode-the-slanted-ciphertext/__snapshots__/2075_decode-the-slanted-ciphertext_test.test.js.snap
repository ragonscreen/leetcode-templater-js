describe('decodeCiphertext', () => {
    test.each(structuredClone(testcases))('decodeCiphertext($encodedText, $rows) -> $expected', ({ encodedText, rows, expected }) => {
        expect(decodeCiphertext(encodedText, rows)).toStrictEqual(expected);
    });
});"
