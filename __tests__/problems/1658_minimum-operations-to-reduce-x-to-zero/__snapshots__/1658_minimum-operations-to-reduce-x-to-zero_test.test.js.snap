exports[`1658_minimum-operations-to-reduce-x-to-zero test template: 1658_minimum-operations-to-reduce-x-to-zero 1`] = `
"import { describe, expect, test } from 'bun:test';
import { minOperations } from '../../src/1601-1700/1658_minimum-operations-to-reduce-x-to-zero.js';

const testcases = [
    { nums: [1,1,4,2,3], x: 5, expected: 2 },
    { nums: [5,6,7,8,9], x: 4, expected: -1 },
    { nums: [3,2,20,1,1,3], x: 10, expected: 5 },
];

describe('minOperations', () => {
    test.each(structuredClone(testcases))('minOperations($nums, $x) -> $expected', ({ nums, x, expected }) => {
        expect(minOperations(nums, x)).toStrictEqual(expected);
    });
});"
`;
