exports[`2425_bitwise-xor-of-all-pairings test template: 2425_bitwise-xor-of-all-pairings 1`] = `
"import { describe, expect, test } from 'bun:test';
import { xorAllNums } from '../../src/2401-2500/2425_bitwise-xor-of-all-pairings.js';

const testcases = [
    { nums1: [2,1,3], nums2: [10,2,5,0], expected: 13 },
    { nums1: [1,2], nums2: [3,4], expected: 0 },
];

describe('xorAllNums', () => {
    test.each(structuredClone(testcases))('xorAllNums($nums1, $nums2) -> $expected', ({ nums1, nums2, expected }) => {
        expect(xorAllNums(nums1, nums2)).toStrictEqual(expected);
    });
});"
`;
