describe('findDisappearedNumbers', () => {
    test.each(structuredClone(testcases))('findDisappearedNumbers($nums) -> $expected', ({ nums, expected }) => {
        expect(findDisappearedNumbers(nums)).toStrictEqual(expected);
    });
});"
