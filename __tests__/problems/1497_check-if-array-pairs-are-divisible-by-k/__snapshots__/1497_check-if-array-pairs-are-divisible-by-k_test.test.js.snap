import { canArrange } from '../../src/1401-1500/1497_check-if-array-pairs-are-divisible-by-k.js';

const testcases = [
    { arr: [1,2,3,4,5,10,6,7,8,9], k: 5, expected: true },
    { arr: [1,2,3,4,5,6], k: 7, expected: true },
    { arr: [1,2,3,4,5,6], k: 10, expected: false },
