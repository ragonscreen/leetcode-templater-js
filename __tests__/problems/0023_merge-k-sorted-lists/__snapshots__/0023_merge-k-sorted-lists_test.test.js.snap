const testcases = [
    { lists: [[1,4,5],[1,3,4],[2,6]], expected: [1,1,2,3,4,4,5,6] },
    { lists: [], expected: [] },
    { lists: [[]], expected: [] },
];

describe('mergeKLists', () => {
    test.each(structuredClone(testcases))('mergeKLists($lists) -> $expected', ({ lists, expected }) => {
        expect(mergeKLists(lists)).toStrictEqual(expected);
    });
});"
`;
